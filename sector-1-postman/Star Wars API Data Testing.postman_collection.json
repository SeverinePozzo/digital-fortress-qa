        {
          "name": "409 Validate Data Conflict Boundary",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Assert precise HTTP status boundary\r",
                  "pm.test(\"Status code is exactly 409 Conflict\", function () {\r",
                  "    pm.response.to.have.status(409);\r",
                  "});\r",
                  "\r",
                  "// Assert business logic exception text\r",
                  "pm.test(\"Payload details the exact resource conflict trace\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "\r",
                  "    pm.expect(jsonData.error).to.equal(\"Conflict\");\r",
                  "    pm.expect(jsonData.message).to.include(\"already assigned\");\r",
                  "});"
