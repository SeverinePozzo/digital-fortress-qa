{
  "info": {
    "_postman_id": "421e6ed5-34d0-48c3-8906-a8c5d9595ebf",
    "name": "Star Wars API Data Testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "55377696",
