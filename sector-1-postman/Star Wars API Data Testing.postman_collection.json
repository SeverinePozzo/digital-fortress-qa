  "item": [
    {
      "name": "Pilot Verification Flight Log Workflow",
      "item": [
        {
          "name": "Fetch the Character & Isolate the Starship",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Character found successfully\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "    const jsonData = pm.response.json();\r",
                  "    \r",
                  "    // Assert structural integrity of the search array\r",
                  "    pm.expect(jsonData.results).to.be.an('array').that.is.not.empty;\r",
                  "    const character = jsonData.results[0];\r",
                  "    pm.expect(character.name).to.equal(\"Luke Skywalker\");\r",
                  "\r",
                  "    // Extract relational hypermedia links\r",
                  "    const firstStarshipUrl = character.starships[0]; // e.g., X-wing URL\r",
                  "    const homeworldUrl = character.homeworld;\r",
                  "\r",
                  "    pm.expect(firstStarshipUrl).to.exist.and.be.a('string');\r",
                  "    pm.expect(homeworldUrl).to.exist.and.be.a('string');\r",
                  "\r",
                  "    // Save as collection variables \r",
                  "    pm.collectionVariables.set(\"nextStarshipUrl\", firstStarshipUrl);\r",
                  "    pm.collectionVariables.set(\"homeworldUrl\", homeworldUrl);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}api/people/?search=Luke Skywalker",
              "host": [
                "{{baseUrl}}api"
              ],
              "path": [
                "people",
                ""
              ],
              "query": [
                {
                  "key": "search",
                  "value": "Luke Skywalker"
                }
              ]
            },
            "description": "StartFragmentVerify the profile and dynamically capture their first available starship and their homeworld."
          },
          "response": []
        },
        {
          "name": "Query the Extracted Ship",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Validate pilot's starship specifications\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "    const shipData = pm.response.json();\r",
                  "\r",
                  "    // Verify a valid vehicle sheet was pulled\r",
                  "    pm.expect(shipData).to.have.property('name');\r",
                  "    pm.expect(shipData).to.have.property('hyperdrive_rating');\r",
                  "    \r",
                  "    // Log specification directly into Postman Console\r",
                  "    console.log(`Validating Ship: ${shipData.name} | Hyperdrive Class: ${shipData.hyperdrive_rating}`);\r",
                  "\r",
                  "    // Ensure it isn't an invalid/null hyperdrive asset\r",
                  "    pm.expect(shipData.hyperdrive_rating).to.not.equal(\"unknown\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{nextStarshipUrl}}",
              "host": [
                "{{nextStarshipUrl}}"
              ]
            },
            "description": "StartFragment Extract ship specifications dynamically based on what was passed from Step 1."
          },
          "response": []
        },
        {
          "name": "Verify the Target Homeworld Environment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Verify destination planet status\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "    const planetData = pm.response.json();\r",
                  "\r",
                  "    // Structural and data type checks on the final node\r",
                  "    pm.expect(planetData.name).to.be.a('string').and.not.empty;\r",
                  "    pm.expect(planetData.climate).to.be.a('string');\r",
                  "    \r",
                  "    // Tear down collection variables to keep the environment clean post-run\r",
                  "    pm.collectionVariables.unset(\"nextStarshipUrl\");\r",
                  "    pm.collectionVariables.unset(\"homeworldUrl\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{homeworldUrl}}",
              "host": [
                "{{homeworldUrl}}"
              ]
            },
            "description": "Verify that the initial destination fetched in Step 1 resolves to a valid, intact location profile."
          },
          "response": []
        }
      ],
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              ""
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "// Validate that the response code is within the successful 2xx range\r",
              "pm.test(\"Status code is 2xx Success\", function () {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 202, 204]);\r",
              "});\r",
              "\r",
              "// Exact status code mapping based on HTTP Method\r",
              "const currentMethod = pm.request.method;\r",
              "\r",
              "if (currentMethod === \"POST\") {\r",
              "    pm.test(\"POST Request: Status code is 201 Created or 200 OK\", function () {\r",
              "        pm.expect(pm.response.code).to.be.oneOf([200, 201]);\r",
              "    });\r",
              "} else if (currentMethod === \"DELETE\") {\r",
              "    pm.test(\"DELETE Request: Status code is 200 OK or 204 No Content\", function () {\r",
              "        pm.expect(pm.response.code).to.be.oneOf([200, 204]);\r",
              "    });\r",
              "}\r",
              "\r",
              "// Performance Check\r",
              "pm.test(\"Response time is under 800ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(800);\r",
              "});\r",
              "\r",
              "// Security Check: Assert that the response explicitly protects or defines headers\r",
              "pm.test(\"Security: Content-Type header is present\", function () {\r",
              "    pm.response.to.have.header(\"Content-Type\");\r",
              "});\r",
              "// Only run success checks if we aren't deliberately testing an error path\r",
              "if (!pm.variables.get(\"isNegativeTestCase\")) {\r",
              "    pm.test(\"Status code is 2xx Success\", function () {\r",
              "        pm.expect(pm.response.code).to.be.oneOf([200, 201, 202, 204]);\r",
              "    });\r",
              "}"
            ]
          }
        }
      ]
    },
