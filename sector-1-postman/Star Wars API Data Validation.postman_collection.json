      "name": "Mock Contract Suite",
      "item": [
        {
          "name": "Missing profile check 404",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Verify Status Code Layer for Deleted/Missing Data - must return a 404 Not Found\r",
                  "pm.test(\"Status code is 404 Not Found for missing or deleted resource\", function () {\r",
                  "    pm.response.to.have.status(404);\r",
                  "});\r",
                  "\r",
                  "// Validate Error Structure\r",
                  "pm.test(\"Server returns a valid JSON error message payload\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    \r",
                  "// SWAPI handles missing data by returning a 'detail' property\r",
                  "    pm.expect(jsonData).to.have.property('detail');\r",
                  "    pm.expect(jsonData.detail).to.be.a('string');\r",
                  "    pm.expect(jsonData.detail.toLowerCase()).to.include(\"not found\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.variables.set(\"isNegativeTestCase\", true);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
