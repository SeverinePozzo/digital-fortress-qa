        {
          "name": "Resource wiping guard 405",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Assert that the server blocks the deletion with a 405 status code\r",
                  "pm.test(\"Status code is 405 Method Not Allowed\", function () {\r",
                  "    pm.response.to.have.status(405);\r",
                  "});\r",
                  "\r",
                  "// Security Check: verify that the response payload confirms the refusal\r",
                  "pm.test(\"Server response body explicitly identifies unauthorized method\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    \r",
                  "    // Framework returns a detail or error string \r",
                  "    pm.expect(jsonData).to.have.property('detail');\r",
                  "    pm.expect(jsonData.detail.toLowerCase()).to.include(\"not allowed\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.variables.set(\"isNegativeTestCase\", true);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}api/people/1/",
              "host": [
                "{{baseUrl}}api"
              ],
              "path": [
