        {
          "name": "Data Injection Guard",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "//Status Code Assertion: the server rejects the creation with a 405 Method Not Allowed or 403 Forbidden\r",
                  "pm.test(\"TC-001: Server blocks unauthorized creation with 405 status code\", function () {\r",
                  "    pm.response.to.have.status(405);\r",
                  "});\r",
                  "\r",
                  "// Data & Error Contract Assertion\r",
                  "// Ensure that the server returns a proper JSON error detailing that creation is prohibited\r",
                  "pm.test(\"TC-002: Error payload explicitly states POST actions are disallowed\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    \r",
                  "    // Check that an error detail property exists\r",
                  "    pm.expect(jsonData).to.have.property('detail');\r",
                  "    \r",
                  "    // Check that the text tells the developer why it failed\r",
                  "    pm.expect(jsonData.detail.toLowerCase()).to.include(\"not allowed\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.variables.set(\"isNegativeTestCase\", true);"
